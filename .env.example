# ──── Master Server ────
# WebSocket URL of the NestJS trade copier server
SERVER_URL=wss://yourserver.com

# ──── Slave Identity ────
# Must match an account in the server's accounts.json
ACCOUNT_ID=apex_eval_1
SLAVE_KEY=your-secret-key-here

# ──── Playwright ────
# Port that Chrome is listening on (launched with --remote-debugging-port)
CHROME_DEBUG_PORT=9222
